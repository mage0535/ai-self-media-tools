{
  "data_dir": "{{CONTENT_PLATFORM_HOME}}/data",
  "generator": {
    "provider": "hermes-cli",
    "allow_fallback": true,
    "env_file": "{{CONTENT_PLATFORM_HOME}}/secrets/provider.env",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-4.1-mini",
    "hermes_command": "hermes",
    "timeout": 180,
    "style_guide_path": "{{CONTENT_PLATFORM_HOME}}/skills/content/content-copywriting-style/SKILL.md"
  },
  "risk": {
    "legacy_script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/safe_filter.py",
    "timeout": 20
  },
  "media": {
    "image": {
      "enabled": true,
      "script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/image_gen.py",
      "method": "pil",
      "timeout": 120
    },
    "video": {
      "enabled": false,
      "platforms": ["douyin", "bilibili", "youtube", "tiktok", "kuaishou", "shipinhao"],
      "script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/video_pipeline.py",
      "timeout": 600
    },
    "audio": {
      "enabled": false,
      "platforms": ["douyin", "bilibili", "youtube", "tiktok", "kuaishou", "shipinhao"],
      "mode": "auto",
      "timeout": 300
    }
  },
  "content_policy": {
    "original_content": "image_text_only",
    "short_video": "repurpose_existing_source_only",
    "allow_local_video_generation": false,
    "allow_local_audio_generation": false
  },
  "content_hygiene": {
    "enabled": true,
    "candidate_limit": 200,
    "block_threshold": 0.72,
    "review_threshold": 0.58
  },
  "ocr": {
    "script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/ocr_pipeline.py",
    "timeout": 120
  },
  "transcription": {
    "script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/transcribe_pipeline.py",
    "timeout": 300
  },
  "analysis": {
    "script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/multimodal_analyze.py",
    "timeout": 180
  },
  "seo": {
    "openserp_host": "{{OPENSERP_HOST}}",
    "default_engine": "duck",
    "geo_checklist_enabled": true,
    "tools": ["openserp", "pyseoanalyzer"]
  },
  "delivery": {
    "max_attempts": 2,
    "backoff_seconds": 1,
    "auto_stage_review_required": true
  },
  "review": {
    "key_path": "{{CONTENT_PLATFORM_HOME}}/data/review.key",
    "token_ttl_seconds": 86400
  },
  "trends": {
    "legacy_data_dir": "{{CONTENT_PLATFORM_HOME}}/data/trend-cache",
    "legacy_script": "{{CONTENT_PLATFORM_HOME}}/external/scripts/trend_collector.py"
  },
  "publishers": {
    "routing_defaults": {
      "enabled": true,
      "domestic": {
        "type": "social-auto-upload",
        "account_name": "<account-alias>"
      },
      "international": {
        "type": "aitoearn-draft",
        "base_url": "https://aitoearn.ai/api/unified/mcp",
        "api_key_env": "AITOEARN_INTL_API_KEY"
      }
    },
    "default": {
      "type": "file",
      "outbox": "{{CONTENT_PLATFORM_HOME}}/data/outbox"
    }
  },
  "notifications": {
    "log_path": "{{CONTENT_PLATFORM_HOME}}/data/notifications.jsonl",
    "network_enabled": false
  }
}
